{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Capability for the floating window and menu-bar panel",
  "windows": ["main", "panel"],
  "permissions": [
    "core:default",
    "core:window:allow-hide",
    "core:window:allow-start-dragging",
    "core:window:allow-set-size",
    "opener:default"
  ]
}
